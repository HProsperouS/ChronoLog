# Server
PORT=3001
HOST=127.0.0.1
NODE_ENV=development

# Data storage directory (default: ./data)
DATA_DIR=./data

# AI Insights — calls your AWS Lambda Function URL (OpenAI key lives only in Lambda)
INSIGHTS_FUNCTION_URL=https://xxxx.lambda-url.ap-southeast-1.on.aws/
INSIGHTS_PROXY_SECRET=your-long-random-secret-same-as-cdk-ProxySecret
