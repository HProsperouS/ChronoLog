{
  "settings": {
    "trackingEnabled": false,
    "idleDetectionEnabled": true,
    "notificationsEnabled": true,
    "launchAtStartup": true,
    "runInBackground": true,
    "pollIntervalSeconds": 5,
    "idleThresholdMinutes": 5,
    "retentionDays": 90
  },
  "privacy": {
    "excludedApps": [
      "GitHub Desktop",
      "IntelliJ IDEA"
    ],
    "respectPrivateBrowsing": true
  }
}